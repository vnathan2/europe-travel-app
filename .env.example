# ===========================================================================
# .env.example — Plantilla de variables de entorno para europe-travel-app
# ===========================================================================
# Copia este archivo como `.env` y completa los valores. NO commitees `.env`
# (ya está en .gitignore).
#
# En producción (Cloud Run), estas variables vienen de:
#   1. Secret Manager (claves sensibles): GEMINI_API_KEY, TAVILY_API_KEY,
#      GOOGLE_CLIENT_SECRET, OPENTRIPMAP_API_KEY.
#   2. Variables de entorno del service (no sensibles): APP_MODE, GCP_PROJECT_ID,
#      GCS_BUCKET_NAME, ADMIN_EMAIL, FAMILIAR_EMAIL_*, OAUTH_REDIRECT_URI.
# Ver scripts/setup_secrets.sh para el flujo de carga a Secret Manager.
# ===========================================================================


# ── Modo de la app ─────────────────────────────────────────────────────────
# PRODUCTION: requiere OAuth con Google (default).
# DEVELOPMENT: bypassa OAuth con un usuario ADMIN dummy, útil para iterar
# rápido en local. NUNCA usar en Cloud Run.
APP_MODE=DEVELOPMENT


# ── Google OAuth (auth/google_oauth.py) ────────────────────────────────────
# Credenciales del cliente OAuth registrado en Google Cloud Console
# (APIs & Services > Credentials > OAuth 2.0 Client IDs).
GOOGLE_CLIENT_ID=tu-cliente-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-completar-aqui

# URI a la que Google redirige después del login. Debe coincidir EXACTAMENTE
# con la "Authorized redirect URI" registrada en Google Cloud Console.
# Para local: http://localhost:8501
# Para Cloud Run: https://europe-travel-app-565528729494.us-east1.run.app
OAUTH_REDIRECT_URI=http://localhost:8501

# Emails autorizados con sus roles. ADMIN ve precios y módulos restringidos
# (night_life, admin_panel). FAMILIAR no ve precios.
ADMIN_EMAIL=jonathan@ejemplo.com
FAMILIAR_EMAIL_1=giovanna@ejemplo.com
FAMILIAR_EMAIL_2=camila@ejemplo.com

# Si true, el login muestra la URI activa en pantalla (útil para debuggear
# mismatches con la Redirect URI de Google Cloud Console).
DEBUG_AUTH=false


# ── Google Cloud (utils/gcp_client.py) ─────────────────────────────────────
# Project ID del proyecto GCP donde están Firestore, Storage y Secret Manager.
GCP_PROJECT_ID=europe-travel-app

# Bucket de Cloud Storage para fotos del Trip Journal (privadas, no public).
GCS_BUCKET_NAME=europe-travel-app-bucket


# ── APIs externas (utils/knowledge_base.py, modules/travel_concierge.py) ───
# Gemini: requerido para el chat de Lady, embeddings del RAG, y generación
# de sugerencias en birthday_planner y shopping_guide. Obtener en
# https://makersuite.google.com/app/apikey
GEMINI_API_KEY=tu-clave-gemini-aqui

# Tavily: búsqueda web augmented para Lady cuando emite [BUSCAR_WEB:].
# Free tier: 1000 queries/mes. Obtener en https://tavily.com
TAVILY_API_KEY=tu-clave-tavily-aqui

# OpenTripMap (opcional): atracciones turísticas para el RAG. Si no se
# define, el script de ingesta cae a Overpass de OpenStreetMap.
OPENTRIPMAP_API_KEY=


# ── Helpers de fallback (utils/price_helper.py) ────────────────────────────
# Tasa EUR→PEN usada si exchangerate-api falla. Ajustar 1-2 veces al mes
# según BCRP (https://www.bcrp.gob.pe/) para no quedar desactualizado.
FALLBACK_EUR_PEN_RATE=3.95


# ── Scripts de ingesta (scripts/ingest_knowledge.py) ───────────────────────
# Filtra las ciudades a ingestar. CSV, vacío = todas las 5.
# Ej: INGEST_CITIES=Madrid,Bayona
INGEST_CITIES=

# Si "1" o "true", omite Tavily durante la ingesta para ahorrar créditos.
INGEST_SKIP_TAVILY=
